# Copy this file to `.env` and fill in the provider you want to use.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1

# MiniMax
MINIMAX_API_KEY=
MINIMAX_MODEL=
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Optional domain-chip overrides
DOMAIN_CHIP_MEMORY_OPENAI_MODEL=
DOMAIN_CHIP_MEMORY_OPENAI_BASE_URL=
DOMAIN_CHIP_MEMORY_MINIMAX_MODEL=
DOMAIN_CHIP_MEMORY_MINIMAX_BASE_URL=
